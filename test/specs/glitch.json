{
  "suite": "glitch",
  "description": "GlitchHandler: sub-nominal dips shorter than max_gap_ms are forgiven",
  "handler": "GlitchHandler",
  "step": { "op": "glitch_ignore", "ref": "nominal_mA", "max_gap_ms": 100 },
  "runtime_defaults": { "nominal_mA": 300, "setpoint_mA": 350 },
  "cases": [
    {
      "id": "no_dip",
      "description": "Current always above nominal — effectiveI = actual I throughout",
      "samples": [
        { "t_ms": 0,   "I_mA": 400 },
        { "t_ms": 50,  "I_mA": 420 },
        { "t_ms": 100, "I_mA": 410 }
      ],
      "expect": {
        "per_sample": [
          { "t_ms": 0,   "effectiveI": 400 },
          { "t_ms": 50,  "effectiveI": 420 },
          { "t_ms": 100, "effectiveI": 410 }
        ]
      }
    },
    {
      "id": "short_dip_forgiven",
      "description": "50 ms dip below nominal (< 100 ms limit) — effectiveI = pre-dip hold",
      "samples": [
        { "t_ms": 0,   "I_mA": 400 },
        { "t_ms": 100, "I_mA": 400 },
        { "t_ms": 110, "I_mA": 50  },
        { "t_ms": 140, "I_mA": 50  },
        { "t_ms": 155, "I_mA": 50  },
        { "t_ms": 200, "I_mA": 400 }
      ],
      "expect": {
        "per_sample": [
          { "t_ms": 110, "effectiveI": 400 },
          { "t_ms": 140, "effectiveI": 400 },
          { "t_ms": 155, "effectiveI": 400 },
          { "t_ms": 200, "effectiveI": 400 }
        ]
      }
    },
    {
      "id": "long_dip_committed",
      "description": "Dip first drops at t=110ms; at t=220ms gap=110ms > 100ms limit → committed → effectiveI = actual I",
      "samples": [
        { "t_ms": 0,   "I_mA": 400 },
        { "t_ms": 100, "I_mA": 400 },
        { "t_ms": 110, "I_mA": 50  },
        { "t_ms": 220, "I_mA": 50  },
        { "t_ms": 300, "I_mA": 400 }
      ],
      "expect": {
        "per_sample": [
          { "t_ms": 220, "effectiveI": 50 },
          { "t_ms": 300, "effectiveI": 400 }
        ]
      }
    },
    {
      "id": "still_forgiven_at_99ms",
      "description": "At t=209ms gap=99ms < 100ms — still forgiven, effectiveI = hold value",
      "samples": [
        { "t_ms": 0,   "I_mA": 400 },
        { "t_ms": 100, "I_mA": 400 },
        { "t_ms": 110, "I_mA": 50  },
        { "t_ms": 209, "I_mA": 50  },
        { "t_ms": 300, "I_mA": 400 }
      ],
      "expect": {
        "per_sample": [
          { "t_ms": 209, "effectiveI": 400 },
          { "t_ms": 300, "effectiveI": 400 }
        ]
      }
    }
  ]
}
