{
  "suite": "duration",
  "description": "DurationHandler: accumulate time where both current and prev sample are above nominal until required duration is met",
  "handler": "DurationHandler",
  "step": {
    "op": "min_duration_above",
    "threshold": "nominal_mA",
    "duration_from": "required_duration_s",
    "completion_threshold_percent": 100
  },
  "runtime_defaults": { "nominal_mA": 300, "setpoint_mA": 350, "required_duration_s": 3.0 },
  "cases": [
    {
      "id": "exactly_meets_requirement",
      "description": "3 s of continuous above-nominal current — completedAt set at the 3 s mark",
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 400 },
        { "t_ms": 1000, "I_mA": 400 },
        { "t_ms": 2000, "I_mA": 400 },
        { "t_ms": 3000, "I_mA": 400 },
        { "t_ms": 3500, "I_mA": 400 }
      ],
      "expect": {
        "violations": [],
        "completedAt_ms": 3000
      }
    },
    {
      "id": "gap_pauses_accumulation",
      "description": "A 1 s dip below nominal pauses the counter; gap warning fires when gap closes (t=3020), completion fires later at t=4020",
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 400 },
        { "t_ms": 2000, "I_mA": 400 },
        { "t_ms": 2010, "I_mA": 100 },
        { "t_ms": 3010, "I_mA": 400 },
        { "t_ms": 3020, "I_mA": 400 },
        { "t_ms": 4020, "I_mA": 400 }
      ],
      "expect": {
        "violations": [{ "severity": "warn", "messageKey": "below_threshold_gap" }],
        "completedAt_ms": 4020
      }
    },
    {
      "id": "completion_threshold_80pct",
      "description": "completion_threshold_percent=80 with required=2.5 s → only 2.0 s needed; completion fires at t=2000",
      "step_override": { "completion_threshold_percent": 80 },
      "runtime": { "required_duration_s": 2.5 },
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 400 },
        { "t_ms": 2000, "I_mA": 400 },
        { "t_ms": 3000, "I_mA": 400 }
      ],
      "expect": {
        "violations": [],
        "completedAt_ms": 2000
      }
    },
    {
      "id": "current_threshold_80pct_passes",
      "description": "current_threshold_percent=80 → effective threshold = 80% of 300 mA = 240 mA; current at 250 mA always above 240 mA → completes normally",
      "step_override": { "current_threshold_percent": 80 },
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 250 },
        { "t_ms": 1000, "I_mA": 250 },
        { "t_ms": 2000, "I_mA": 250 },
        { "t_ms": 3000, "I_mA": 250 }
      ],
      "expect": {
        "violations": [],
        "completedAt_ms": 3000
      }
    },
    {
      "id": "current_threshold_80pct_below_nominal_no_completion",
      "description": "current_threshold_percent=80 → effective threshold 240 mA; current at 250 mA above 240 mA but NOT 100% nominal — without scaling this would be below nominal and never complete",
      "step_override": { "current_threshold_percent": 80 },
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 250 },
        { "t_ms": 1000, "I_mA": 250 },
        { "t_ms": 2000, "I_mA": 250 },
        { "t_ms": 3000, "I_mA": 250 }
      ],
      "expect": {
        "violations": [],
        "completedAt_ms": 3000
      }
    },
    {
      "id": "current_threshold_80pct_gap_below_effective",
      "description": "current_threshold_percent=80 → effective threshold 240 mA; current dips to 230 mA (below 240 mA) → gap warning fires; completes late",
      "step_override": { "current_threshold_percent": 80 },
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 250 },
        { "t_ms": 2000, "I_mA": 250 },
        { "t_ms": 2010, "I_mA": 230 },
        { "t_ms": 3010, "I_mA": 250 },
        { "t_ms": 3020, "I_mA": 250 },
        { "t_ms": 4020, "I_mA": 250 }
      ],
      "expect": {
        "violations": [{ "severity": "warn", "messageKey": "below_threshold_gap" }],
        "completedAt_ms": 4020
      }
    },
    {
      "id": "current_threshold_80pct_never_reached",
      "description": "current_threshold_percent=80 → effective threshold 240 mA; current at 230 mA always below effective threshold → duration_not_reached",
      "step_override": { "current_threshold_percent": 80 },
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 230 },
        { "t_ms": 1000, "I_mA": 230 },
        { "t_ms": 5000, "I_mA": 230 }
      ],
      "expect": {
        "violations": [
          { "severity": "error", "messageKey": "duration_not_reached", "isSummary": true }
        ],
        "completedAt_ms": null
      }
    },
    {
      "id": "never_reached",
      "description": "Only 1 s above nominal — duration_not_reached summary violation emitted",
      "accumulate_start_ms": 0,
      "samples": [
        { "t_ms": 0,    "I_mA": 400 },
        { "t_ms": 1000, "I_mA": 400 },
        { "t_ms": 1010, "I_mA": 100 },
        { "t_ms": 5000, "I_mA": 100 }
      ],
      "expect": {
        "violations": [
          { "severity": "error", "messageKey": "duration_not_reached", "isSummary": true }
        ],
        "completedAt_ms": null
      }
    }
  ]
}
