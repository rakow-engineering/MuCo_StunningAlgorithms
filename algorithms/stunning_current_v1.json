{
  "schema_version": "1.0",
  "algorithm_id": 2,
  "display_name": "Standard",
  "description": "Klassische Auswertung: Anstieg auf setpoint_mA in 1s, dann dauerhaft >= nominal_mA (rot) / >= setpoint_mA (gelb), Mindest-Betäubungszeit über nominal_mA.",
  "bindings": {
    "series": "I_mA",
    "nominal_mA": "default_current_mA",
    "setpoint_mA": "current_mA",
    "required_duration_s": "time_s"
  },
  "timebase": "t_ms",
  "steps": [
    {
      "id": "glitch_ignore",
      "op": "glitch_ignore",
      "type": "filter",
      "enabled": true,
      "max_gap_ms": 100
    },
    {
      "id": "ramp",
      "op": "ramp_to_threshold",
      "type": "startup",
      "threshold": "setpoint_mA",
      "current_threshold_percent": 100,
      "timeout_ms": 1000,
      "ramp_start_mA": 10,
      "count_during_ramp": false
    },
    {
      "id": "sustain",
      "op": "sustain_thresholds",
      "type": "monitor",
      "enabled": true,
      "after": "after_ramp",
      "warn_below": "setpoint_mA",
      "warn_below_threshold_percent": 100,
      "fail_below": "nominal_mA",
      "fail_below_threshold_percent": 100
    },
    {
      "id": "duration",
      "op": "min_duration_above",
      "type": "completion",
      "enabled": true,
      "threshold": "nominal_mA",
      "current_threshold_percent": 100,
      "duration_from": "required_duration_s",
      "completion_threshold_percent": 100
    },
    {
      "id": "invalid_check",
      "op": "invalid_timeout",
      "type": "completion",
      "enabled": true,
      "max_invalid_s": 0.5
    },
    {
      "id": "total_check",
      "op": "total_timeout",
      "type": "completion",
      "enabled": true,
      "duration_from": "required_duration_s",
      "factor": 3.0
    }
  ]
}
